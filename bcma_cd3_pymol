# color linkers
select linkers, pepseq GGGGS
color gray, linkers

# interface selection and assignment, 5 angstrom (there are none <= 5 angstrom)
select cd3e-res-near-cd3, byres (cd3e within 5 of hc_cd3)
select cd3-res-near-cd3e, byres (hc_cd3 within 5 of cd3e)

select cd3e-res-near-bcma, byres (cd3e within 5 of (hc_bcma_1 or hc_bcma_2))
select bcma-res-near-cd3e, byres ((hc_bcma_1 or hc_bcma_2) within 5 of cd3e)

# note: can use more than two and can compare groups against groups 
select non-cd3-res-near-cd3-dimers, byres ((hc_bcma_1 or hc_bcma_2 or lc) within 5 of (cd3e or cd3d or cd3g))
select cd3-dimers-res-near-non-cd3, byres ((cd3e or cd3d or cd3g) within 5 of (hc_bcma_1 or hc_bcma_2 or lc))
deselect

# use the following, substituting selectionname for the selection from one of the above to print the chain and residue that overlaps
